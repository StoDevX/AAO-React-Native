{
  "useTabs": true,
  "singleQuote": true,
  "trailingComma": "all",
  "bracketSpacing": false,
  "semi": false,
  "printWidth": 80,
  "sortPackageJson": false,
  "ignorePatterns": [
    "*.md",
    "node_modules/",
    "/flow-typed/",
    "/docs/",
    "/data/bus-times/*.yaml",
    "/android/",
    "/ios/",
    "/package-lock.json"
  ],
  "overrides": [
    {
      "files": ["**/*.json", "**/.*.json"],
      "options": {
        "useTabs": false,
        "tabWidth": 2
      }
    }
  ]
}
